API_BASE_URL=https://dummyjson.com
HTTP_TIMEOUT_MS=8000
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=300
CAMPAIGNS_LIMIT=30
THRESHOLD_WARNING=2.5
THRESHOLD_CRITICAL=1.0
OUTPUT_PATH=./data/campaigns.json
LLM_OUTPUT_PATH=./data/llm-summary.json

# Parte 2 — N8N (opcional)
# N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/inlaze-campaign-monitor

# Parte 4 — LLM (requerido para generar el resumen ejecutivo)
# Obtener API key gratuita en https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL='meta-llama/llama-3.3-70b-instruct:free'
LLM_TIMEOUT_MS=30000
